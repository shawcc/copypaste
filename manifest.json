{
  "manifest_version": 3,
  "name": "文案大师·傅",
  "version": "0.1.0",
  "description": "从飞书文档 PRD 中提取选区文案与配图，并生成可粘贴到飞书的表格。",
  "action": {
    "default_title": "文案大师·傅",
    "default_icon": "icon.svg"
  },
  "icons": {
    "128": "icon.svg"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["activeTab", "scripting", "storage", "clipboardWrite", "clipboardRead", "contextMenus", "sidePanel", "webRequest"],
  "host_permissions": [
    "*://*.feishu.cn/*",
    "*://*.larksuite.com/*",
    "*://*.larkoffice.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "cp_extract_selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "提取当前选区（CopyPaste）"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.feishu.cn/*", "https://*.larksuite.com/*", "https://*.larkoffice.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
